@startuml Projeto_Quimera_Diagrama_de_Componentes
title Projeto Quimera - Arquitetura de Componentes e Integração

!define RECTANGLE class

skinparam component {
    BackgroundColor<<Core>> LightBlue
    BackgroundColor<<Agent>> LightGreen
    BackgroundColor<<Service>> LightYellow
    BackgroundColor<<External>> LightGray
    BackgroundColor<<Storage>> LightPink
}

' ===== CAMADA DE APRESENTAÇÃO =====

package "Camada de Apresentação" {
    [Interface Web\nDashboard] as WebUI <<Core>>
    [Painel de Controle\nHandoff] as PainelHandoff <<Core>>
    [Sistema de Notificações\nPush/Email/SMS] as Notificacoes <<Core>>
}

' ===== CAMADA DE ORQUESTRAÇÃO =====

package "Camada de Orquestração e Controle" {
    [Orquestrador Central\nWorkflow Engine] as Orquestrador <<Core>>
    [Gerenciador de Estado\nState Machine] as GerenciadorEstado <<Core>>
    [Scheduler de Tarefas\nCron/Interval] as Scheduler <<Core>>
    [Monitor de Saúde\nHealth Check] as MonitorSaude <<Core>>
}

' ===== CAMADA DE AGENTES =====

package "Camada de Agentes Inteligentes" {
    
    component "Agente Batedor\n(Scout Agent)" as AgenteBatedor <<Agent>> {
        [Módulo de Navegação\nFurtiva]
        [Extrator de Perfis]
        [Coletor de Hashtags]
        [Mapeador de Hotspots]
    }
    
    component "Agente Analista\n(Analyst Agent)" as AgenteAnalista <<Agent>> {
        [Analisador de Texto\nNLP]
        [Analisador de Imagens\nComputer Vision]
        [Calculador de Pontuação]
        [Detector de Afinidades]
        [Inferidor de Status]
    }
    
    component "Motor de Persuasão\n(Persuasion Engine)" as MotorPersuasao <<Agent>> {
        [Seletor de Princípios\nCialdini]
        [Construtor de Pilha\nde Persuasão]
        [Identificador de Gatilhos\nEmocionais]
        [Estrategista de Abertura]
    }
    
    component "Agente Escriba\n(Scribe Agent)" as AgenteEscriba <<Agent>> {
        [Construtor de Prompt\nMestre]
        [Gerador de Mensagens\nLLM]
        [Validador de Qualidade]
        [Ajustador de Tom]
        [Gerenciador de Persona\n'Alex']
    }
    
    component "Agente de Execução\n(Execution Agent)" as AgenteExecucao <<Agent>> {
        [Navegador Furtivo]
        [Digitador Humanizado]
        [Monitor de Entrega]
        [Gerenciador de Fila]
    }
    
    component "Agente de Monitoramento\n(Monitoring Agent)" as AgenteMonitoramento <<Agent>> {
        [Scanner de Inbox]
        [Detector de Respostas]
        [Analisador de Sentimento]
        [Classificador de Tipo]
    }
    
    component "Agente de Aprendizagem\n(Learning Agent)" as AgenteAprendizagem <<Agent>> {
        [Coletor de Feedback\nHITL]
        [Seletor de Amostras\nActive Learning]
        [Retreinador de Modelos\nRLHF]
        [Ajustador de Pesos]
    }
}

' ===== CAMADA DE SERVIÇOS =====

package "Camada de Serviços de Negócio" {
    [Serviço de Handoff\nHuman-in-the-Loop] as ServicoHandoff <<Service>>
    [Serviço de Análise\nde Tendências] as ServicoTendencias <<Service>>
    [Serviço de Métricas\ne KPIs] as ServicoMetricas <<Service>>
    [Serviço de Compliance\nLGPD] as ServicoCompliance <<Service>>
    [Serviço de Anti-Detecção\nStealth Layer] as ServicoAntiDeteccao <<Service>>
}

' ===== CAMADA DE INTEGRAÇÃO =====

package "Camada de Integração Externa" {
    [Cliente LLM\nOpenAI/Anthropic] as ClienteLLM <<Service>>
    [Cliente de Proxy\nRotação] as ClienteProxy <<Service>>
    [Cliente de Scraping\nSelenium/Playwright] as ClienteScraping <<Service>>
    [Cliente de Visão\nComputer Vision API] as ClienteVisao <<Service>>
    [Cliente de NLP\nHugging Face] as ClienteNLP <<Service>>
}

' ===== CAMADA DE DADOS =====

package "Camada de Persistência" {
    database "Banco de Dados\nRelacional\n(PostgreSQL)" as BDRelacional <<Storage>>
    database "Banco de Dados\nDocumental\n(MongoDB)" as BDDocumental <<Storage>>
    database "Cache em Memória\n(Redis)" as Cache <<Storage>>
    database "Armazenamento de\nArquivos\n(S3/MinIO)" as ArquivosStorage <<Storage>>
    database "Banco de Vetores\n(Pinecone/Weaviate)" as BDVetores <<Storage>>
}

' ===== SERVIÇOS EXTERNOS =====

cloud "Serviços Externos" {
    [Instagram\nPlataforma] as Instagram <<External>>
    [Facebook\nPlataforma] as Facebook <<External>>
    [OpenAI API\nGPT-4] as OpenAI <<External>>
    [Anthropic API\nClaude] as Anthropic <<External>>
    [Serviço de Proxy\nBrightData/Oxylabs] as ProxyService <<External>>
    [Serviço de Captcha\n2Captcha/AntiCaptcha] as CaptchaService <<External>>
}

' ===== CAMADA DE INFRAESTRUTURA =====

package "Camada de Infraestrutura" {
    [Sistema de Logs\nELK Stack] as Logs <<Service>>
    [Sistema de Monitoramento\nPrometheus/Grafana] as Monitoring <<Service>>
    [Sistema de Backup\nAutomático] as Backup <<Service>>
    [Gerenciador de Segredos\nVault] as Vault <<Service>>
}

' ===== RELACIONAMENTOS - CAMADA DE APRESENTAÇÃO =====

WebUI --> Orquestrador : "Comandos e\nConfigurações"
PainelHandoff --> ServicoHandoff : "Solicita Contexto"
Notificacoes --> AgenteMonitoramento : "Recebe Alertas"
WebUI --> ServicoMetricas : "Consulta KPIs"

' ===== RELACIONAMENTOS - ORQUESTRAÇÃO =====

Orquestrador --> GerenciadorEstado : "Gerencia Estado"
Orquestrador --> Scheduler : "Agenda Tarefas"
Orquestrador --> MonitorSaude : "Verifica Saúde"

Orquestrador --> AgenteBatedor : "Coordena"
Orquestrador --> AgenteAnalista : "Coordena"
Orquestrador --> MotorPersuasao : "Coordena"
Orquestrador --> AgenteEscriba : "Coordena"
Orquestrador --> AgenteExecucao : "Coordena"
Orquestrador --> AgenteMonitoramento : "Coordena"
Orquestrador --> AgenteAprendizagem : "Coordena"

' ===== RELACIONAMENTOS - AGENTES =====

AgenteBatedor --> ClienteScraping : "Usa"
AgenteBatedor --> ServicoAntiDeteccao : "Aplica"
AgenteBatedor --> BDRelacional : "Armazena URLs"

AgenteAnalista --> ClienteNLP : "Analisa Texto"
AgenteAnalista --> ClienteVisao : "Analisa Imagens"
AgenteAnalista --> BDRelacional : "Persiste Análise"
AgenteAnalista --> BDVetores : "Armazena Embeddings"
AgenteAnalista --> Cache : "Cache de Análises"

MotorPersuasao --> AgenteAnalista : "Consome Afinidades"
MotorPersuasao --> BDDocumental : "Consulta Estratégias"

AgenteEscriba --> ClienteLLM : "Gera Mensagens"
AgenteEscriba --> MotorPersuasao : "Consome Estratégia"
AgenteEscriba --> BDDocumental : "Armazena Prompts"

AgenteExecucao --> ClienteScraping : "Envia Mensagens"
AgenteExecucao --> ServicoAntiDeteccao : "Aplica"
AgenteExecucao --> BDRelacional : "Registra Envios"

AgenteMonitoramento --> ClienteScraping : "Monitora Inbox"
AgenteMonitoramento --> ClienteNLP : "Analisa Respostas"
AgenteMonitoramento --> Notificacoes : "Dispara Alertas"
AgenteMonitoramento --> ServicoHandoff : "Aciona Handoff"

AgenteAprendizagem --> BDRelacional : "Coleta Feedback"
AgenteAprendizagem --> BDVetores : "Retreina Modelos"
AgenteAprendizagem --> AgenteAnalista : "Atualiza Pesos"

' ===== RELACIONAMENTOS - SERVIÇOS =====

ServicoHandoff --> PainelHandoff : "Fornece Contexto"
ServicoHandoff --> BDRelacional : "Consulta Dados"

ServicoTendencias --> Instagram : "Monitora Hashtags"
ServicoTendencias --> Facebook : "Monitora Eventos"
ServicoTendencias --> BDRelacional : "Armazena Tendências"

ServicoMetricas --> BDRelacional : "Consulta Métricas"
ServicoMetricas --> Cache : "Cache de KPIs"

ServicoCompliance --> BDRelacional : "Audita Logs"
ServicoCompliance --> Logs : "Analisa Atividades"

ServicoAntiDeteccao --> ClienteProxy : "Rotaciona Proxies"
ServicoAntiDeteccao --> BDDocumental : "Consulta User-Agents"

' ===== RELACIONAMENTOS - INTEGRAÇÃO EXTERNA =====

ClienteLLM --> OpenAI : "API Calls"
ClienteLLM --> Anthropic : "API Calls"

ClienteScraping --> Instagram : "Scraping/Automação"
ClienteScraping --> Facebook : "Scraping/Automação"

ClienteProxy --> ProxyService : "Requisita Proxies"

ClienteScraping --> CaptchaService : "Resolve Captchas"

' ===== RELACIONAMENTOS - INFRAESTRUTURA =====

Orquestrador --> Logs : "Registra Eventos"
AgenteBatedor --> Logs : "Registra Atividades"
AgenteAnalista --> Logs : "Registra Análises"
AgenteEscriba --> Logs : "Registra Gerações"
AgenteExecucao --> Logs : "Registra Envios"

Orquestrador --> Monitoring : "Envia Métricas"
MonitorSaude --> Monitoring : "Publica Status"

BDRelacional --> Backup : "Backup Automático"
BDDocumental --> Backup : "Backup Automático"

Orquestrador --> Vault : "Recupera Segredos"
ClienteLLM --> Vault : "Recupera API Keys"
ClienteScraping --> Vault : "Recupera Credenciais"

' ===== NOTAS EXPLICATIVAS =====

note right of AgenteBatedor
  **Responsabilidades:**
  - Prospecção em hotspots digitais
  - Extração furtiva de perfis
  - Mapeamento de ecossistema social
  - Coleta de hashtags e eventos
end note

note right of AgenteAnalista
  **Técnicas Utilizadas:**
  - NLP (BERT, GPT embeddings)
  - Computer Vision (ResNet, CLIP)
  - Image Aesthetic Assessment
  - Análise de séries temporais
end note

note right of MotorPersuasao
  **Princípios de Cialdini:**
  1. Reciprocidade
  2. Compromisso e Coerência
  3. Prova Social
  4. Afeição (Liking)
  5. Autoridade
  6. Escassez
end note

note right of AgenteEscriba
  **Modelos LLM Suportados:**
  - GPT-4 (OpenAI)
  - GPT-4.1-mini (OpenAI)
  - Claude 3 (Anthropic)
  - Llama 3 (Meta)
end note

note right of ServicoAntiDeteccao
  **Técnicas Anti-Detecção:**
  - WebDriver modificado
  - Ocultação de navigator.webdriver
  - Randomização de fingerprints
  - Canvas poisoning
  - Delays aleatórios humanizados
  - Simulação de movimentos de mouse
  - Rotação de User-Agent
  - Rotação de Proxy/IP
end note

note right of ServicoHandoff
  **Pacote de Contexto inclui:**
  - Histórico completo da conversa
  - Dados detalhados do perfil
  - Pontuação e ranking
  - Pontos de afinidade identificados
  - Estratégia de persuasão utilizada
  - Link direto para a conversa
  - Sugestões de continuação
end note

note right of AgenteAprendizagem
  **Técnicas de ML:**
  - Active Learning (AL)
    * Amostragem por Incerteza
    * Amostragem por Diversidade
  - RLHF (Reinforcement Learning
    from Human Feedback)
  - Supervised Fine-Tuning (SFT)
  - Decaimento temporal de dados
end note

note bottom of ServicoCompliance
  **Riscos de Compliance:**
  ⚠️ Violação do princípio da
  finalidade da LGPD
  ⚠️ Violação dos ToS das plataformas
  ⚠️ Risco de banimento de contas
  ⚠️ Possível ação da ANPD
end note

@enduml

