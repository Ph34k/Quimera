# ==========================================
# PROJETO QUIMERA - ENVIRONMENTS
# ==========================================

# --- API e Segurança ---
OPENAI_API_KEY=sk-your-openai-api-key-here
SECRET_KEY=sua_chave_secreta_jwt_super_segura
ENVIRONMENT=development

# --- Banco de Dados (PostgreSQL) ---
POSTGRES_USER=quimera_user
POSTGRES_PASSWORD=quimera_password
POSTGRES_DB=quimera_db
POSTGRES_URL=postgresql://quimera_user:quimera_password@localhost:5432/quimera_db
# No docker-compose, o host será 'db' em vez de 'localhost'

# --- Cache e Mensageria (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- Buscas / Vector Database (ElasticSearch) ---
ELASTICSEARCH_URL=http://localhost:9200
